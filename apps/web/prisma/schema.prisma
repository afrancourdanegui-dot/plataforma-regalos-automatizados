// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  image        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  people Person[]

  @@map("users")
}

model Person {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  relationship String
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  occasions Occasion[]
  addresses Address[]

  @@index([userId])
  @@map("people")
}

enum HousingType {
  CASA
  DEPARTAMENTO
}

enum LimaDistrict {
  CERCADO_DE_LIMA
  ANCON
  ATE
  BARRANCO
  BRENA
  CARABAYLLO
  CHACLACAYO
  CHORRILLOS
  CIENEGUILLA
  COMAS
  EL_AGUSTINO
  INDEPENDENCIA
  JESUS_MARIA
  LA_MOLINA
  LA_VICTORIA
  LINCE
  LOS_OLIVOS
  LURIGANCHO
  LURIN
  MAGDALENA_DEL_MAR
  MIRAFLORES
  PACHACAMAC
  PUCUSANA
  PUEBLO_LIBRE
  PUENTE_PIEDRA
  PUNTA_HERMOSA
  PUNTA_NEGRA
  RIMAC
  SAN_BARTOLO
  SAN_BORJA
  SAN_ISIDRO
  SAN_JUAN_DE_LURIGANCHO
  SAN_JUAN_DE_MIRAFLORES
  SAN_LUIS
  SAN_MARTIN_DE_PORRES
  SAN_MIGUEL
  SANTA_ANITA
  SANTA_MARIA_DEL_MAR
  SANTA_ROSA
  SANTIAGO_DE_SURCO
  SURQUILLO
  VILLA_EL_SALVADOR
  VILLA_MARIA_DEL_TRIUNFO
}

model Address {
  id          String       @id @default(cuid())
  personId    String
  person      Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  label       String
  district    LimaDistrict
  street      String
  housingType HousingType  @default(CASA)
  number      String
  isPrimary   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  occasions Occasion[]

  @@index([personId])
  @@map("addresses")
}

enum OccasionType {
  BIRTHDAY
  ANNIVERSARY
  MOTHERS_DAY
  FATHERS_DAY
  VALENTINES
  CHRISTMAS
  GRADUATION
  SPECIAL_DAY
  CUSTOM
}

enum OccasionFrequency {
  MONTHLY
  YEARLY
}

model Occasion {
  id        String            @id @default(cuid())
  personId  String
  person    Person            @relation(fields: [personId], references: [id], onDelete: Cascade)
  type      OccasionType      @default(CUSTOM)
  label     String?
  frequency OccasionFrequency @default(YEARLY)
  month     Int?
  day       Int?
  addressId String?
  address   Address?          @relation(fields: [addressId], references: [id], onDelete: SetNull)
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  giftSelections GiftSelection[]

  @@index([personId])
  @@map("occasions")
}

enum ProductCategory {
  FLORES
  VINOS
  TORTAS
  CHOCOLATES
  SPA
  CAJAS_CURADAS
}

model Product {
  id          String          @id @default(cuid())
  name        String
  brand       String
  category    ProductCategory
  subtype     String?
  price       Decimal         @db.Decimal(10, 2)
  description String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  selections GiftSelection[]
  suppliers  ProductSupplier[]

  @@map("products")
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products ProductSupplier[]

  @@map("suppliers")
}

model ProductSupplier {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  isPrincipal Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([productId, supplierId])
  @@index([productId])
  @@index([supplierId])
  @@map("product_suppliers")
}

model GiftSelection {
  id          String    @id @default(cuid())
  occasionId  String
  occasion    Occasion  @relation(fields: [occasionId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  dueDate     DateTime
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([occasionId, productId])
  @@index([occasionId])
  @@index([productId])
  @@map("gift_selections")
}

// Fila única (id fijo "singleton"): credencial compartida del panel del dueño,
// deliberadamente separada de la tabla User para no mezclar admin con clientes.
model AdminCredential {
  id           String   @id @default("singleton")
  passwordHash String
  updatedAt    DateTime @updatedAt

  @@map("admin_credentials")
}

model AdminPasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("admin_password_reset_tokens")
}
