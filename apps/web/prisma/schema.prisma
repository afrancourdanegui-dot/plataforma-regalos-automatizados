// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  image        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  people Person[]

  @@map("users")
}

model Person {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  relationship String
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  occasions Occasion[]
  addresses Address[]

  @@index([userId])
  @@map("people")
}

enum HousingType {
  CASA
  DEPARTAMENTO
}

enum LimaDistrict {
  CERCADO_DE_LIMA
  ANCON
  ATE
  BARRANCO
  BRENA
  CARABAYLLO
  CHACLACAYO
  CHORRILLOS
  CIENEGUILLA
  COMAS
  EL_AGUSTINO
  INDEPENDENCIA
  JESUS_MARIA
  LA_MOLINA
  LA_VICTORIA
  LINCE
  LOS_OLIVOS
  LURIGANCHO
  LURIN
  MAGDALENA_DEL_MAR
  MIRAFLORES
  PACHACAMAC
  PUCUSANA
  PUEBLO_LIBRE
  PUENTE_PIEDRA
  PUNTA_HERMOSA
  PUNTA_NEGRA
  RIMAC
  SAN_BARTOLO
  SAN_BORJA
  SAN_ISIDRO
  SAN_JUAN_DE_LURIGANCHO
  SAN_JUAN_DE_MIRAFLORES
  SAN_LUIS
  SAN_MARTIN_DE_PORRES
  SAN_MIGUEL
  SANTA_ANITA
  SANTA_MARIA_DEL_MAR
  SANTA_ROSA
  SANTIAGO_DE_SURCO
  SURQUILLO
  VILLA_EL_SALVADOR
  VILLA_MARIA_DEL_TRIUNFO
}

model Address {
  id          String       @id @default(cuid())
  personId    String
  person      Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  label       String
  district    LimaDistrict
  street      String
  housingType HousingType  @default(CASA)
  number      String
  isPrimary   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([personId])
  @@map("addresses")
}

enum OccasionType {
  BIRTHDAY
  ANNIVERSARY
  MOTHERS_DAY
  FATHERS_DAY
  VALENTINES
  CHRISTMAS
  GRADUATION
  SPECIAL_DAY
  CUSTOM
}

enum OccasionFrequency {
  MONTHLY
  YEARLY
}

model Occasion {
  id        String            @id @default(cuid())
  personId  String
  person    Person            @relation(fields: [personId], references: [id], onDelete: Cascade)
  type      OccasionType      @default(CUSTOM)
  label     String?
  frequency OccasionFrequency @default(YEARLY)
  month     Int?
  day       Int?
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([personId])
  @@map("occasions")
}
